theme = catppuccin-mocha.conf
maximize = true

gtk-tabs-location = bottom

font-family = MonaspiceNe Nerd Font
font-size = 13
font-feature = calt,liga,ss01,ss02,ss03,ss04,ss05,ss06,ss07,ss08,ss09,ss10,cv01=2

window-padding-x = 8
window-padding-y = 3

confirm-close-surface = false

# keybinds
keybind = ctrl+shift+h=new_split:right
keybind = ctrl+shift+v=new_split:down
keybind = ctrl+alt+h=goto_split:left
keybind = ctrl+alt+j=goto_split:down
keybind = ctrl+alt+k=goto_split:up
keybind = ctrl+alt+l=goto_split:right

command = /usr/bin/fish
